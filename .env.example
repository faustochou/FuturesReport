# ===== LLM API 配置 =====
# 支持 OpenAI SDK 格式的任意 LLM API
# 推薦使用阿里百煉平台 qwen-plus：https://bailian.console.aliyun.com/
# 注意消耗較大，可先進行小於 40 輪的模擬嘗試
LLM_API_KEY=your_api_key_here
LLM_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
LLM_MODEL_NAME=qwen-plus

# ===== ZEP 記憶圖譜配置 =====
# 每月免費額度即可支撐簡單使用：https://app.getzep.com/
ZEP_API_KEY=your_zep_api_key_here

# ===== 加速 LLM 配置（可選）=====
# 如果不使用加速配置，請不要在 env 文件中保留以下配置項
# LLM_BOOST_API_KEY=your_api_key_here
# LLM_BOOST_BASE_URL=your_base_url_here
# LLM_BOOST_MODEL_NAME=your_model_name_here

# ===== 資料庫配置 =====
# Docker 部署：DATABASE_URL 由 docker-compose.yml 自動注入，無需在此設定
# 源碼部署：留空 → 自動使用 SQLite（無需安裝額外軟件）
# 手動指定 PostgreSQL：
# DATABASE_URL=postgresql://futures:futures123@localhost:5432/futuresreport
DATABASE_URL=

# PostgreSQL 容器帳密（Docker 部署使用，源碼部署可忽略）
POSTGRES_USER=futures
POSTGRES_PASSWORD=futures123
POSTGRES_DB=futuresreport

# ===== 用戶資料目錄 =====
# Docker: 自動掛載到 /data Volume（由 docker-compose.yml 設定）
# 源碼部署：留空即可（SQLite 存入 uploads/ 目錄）
USER_DATA_DIR=/data

# ===== 應用安全金鑰 =====
# 用於 Token 簽名與 API Key 加密，生產環境請換成隨機長字串
# SECRET_KEY=change-me-in-production

# ===== Stripe 金流配置 =====
# 取得金鑰：https://dashboard.stripe.com/apikeys
# 開發測試請使用 sk_test_ / pk_test_ 開頭的測試金鑰
# 正式上線前替換為 sk_live_ / pk_live_ 正式金鑰
STRIPE_SECRET_KEY=sk_test_your_secret_key_here
STRIPE_PUBLISHABLE_KEY=pk_test_your_publishable_key_here
# Webhook Secret：在 Stripe Dashboard → Developers → Webhooks 建立端點後取得
# 端點 URL：https://your-domain.com/api/subscription/webhook
# 需監聽事件：checkout.session.completed、customer.subscription.updated、
#              customer.subscription.deleted、invoice.payment_failed
STRIPE_WEBHOOK_SECRET=whsec_your_webhook_secret_here
# 各方案的 Stripe Price ID（在 Stripe Dashboard → Products 建立訂閱方案後取得）
STRIPE_PRICE_ID_LITE=price_your_lite_price_id_here
# STRIPE_PRICE_ID_PREMIUM=    # 尚未開放，待補
# STRIPE_PRICE_ID_PRO=        # 尚未開放，待補
